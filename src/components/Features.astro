<style>
  .features {
    background: var(--bg);
    padding: 88px 48px;
    border-top: 1px solid var(--border);
  }

  .features-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tabs-nav {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 40px 0 44px;
    justify-content: center;
  }

  .tab-pill {
    font-family: inherit;
    font-size: 13px;
    font-weight: 600;
    padding: 9px 20px;
    border-radius: 100px;
    border: 1.5px solid var(--border2);
    background: #fff;
    color: var(--text2);
    cursor: pointer;
    transition: all .22s;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .tab-pill:hover { border-color: var(--blue); color: var(--blue); }

  .tab-pill.active {
    background: var(--blue);
    color: #fff;
    border-color: var(--blue);
    box-shadow: 0 4px 12px rgba(24, 95, 165, 0.25);
  }

  .tab-panel {
    display: none;
    animation: fadeUp .3s ease;
  }

  .tab-panel.active {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .tab-text h3 {
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .tab-text p {
    font-size: 15px;
    color: var(--text2);
    line-height: 1.75;
    margin-bottom: 26px;
  }

  .tab-feats {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tab-feat-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--text2);
    line-height: 1.5;
  }

  .feat-check-icon {
    width: 22px;
    height: 22px;
    background: var(--green-light);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .tab-micro-cta { margin-top: 24px; }

  .tab-visual {
    background: linear-gradient(145deg, #EEF6FF 0%, #fff 100%);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px;
    box-shadow: var(--shadow);
  }

  .mock-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px;
    box-shadow: var(--shadow);
  }

  .mock-hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
