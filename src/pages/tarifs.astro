---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Tarifs — Zerionyx"
  description="Des tarifs simples et transparents. Starter à 29€/mois, Pro à 79€/mois, Business à 199€/mois. 2 mois offerts pour les premiers inscrits."
>
  <Nav />

  <section class="pricing-hero">
    <h1 class="pricing-hero-title">Des tarifs <span class="t-gradient">simples et transparents</span></h1>
    <p class="pricing-hero-sub">Rentabilisé dès le premier mois. Un technicien à 40€/h qui gagne 3h/semaine récupère 480€/mois de valeur.</p>
  </section>

  <!-- Pricing Cards -->
  <div class="pricing-section">
    <div class="pricing-inner">
      <div class="price-grid">
        <div class="price-card reveal">
          <div class="price-name">Starter</div>
          <div class="price-num"><sup>€</sup>29<span>/mois</span></div>
          <div class="price-for">Pour les indépendants</div>
          <div class="price-div"></div>
          <ul class="price-feats">
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Clients illimités</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Fiches d'intervention + photos</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Signature électronique + PDF</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Historique complet</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>App iOS & Android</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Mode hors ligne</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Support email</li>
          </ul>
          <a href="/#inscription" class="price-btn">Commencer — 2 mois offerts →</a>
        </div>
        <div class="price-card feat reveal">
          <div class="price-pop">⭐ Le plus populaire</div>
          <div class="price-name">Pro</div>
          <div class="price-num"><sup>€</sup>79<span>/mois</span></div>
          <div class="price-for">Jusqu'à 5 techniciens</div>
          <div class="price-div"></div>
          <ul class="price-feats">
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Tout le Starter inclus</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Planning des interventions</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Gestion des équipements</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Alertes & optimisations</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Tableau de bord d'activité</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Import / export des données</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Support prioritaire</li>
          </ul>
          <a href="/#inscription" class="price-btn">Commencer — 2 mois offerts →</a>
        </div>
        <div class="price-card reveal">
          <div class="price-name">Business</div>
          <div class="price-num"><sup>€</sup>199<span>/mois</span></div>
          <div class="price-for">Entreprises structurées</div>
          <div class="price-div"></div>
          <ul class="price-feats">
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Tout le Pro inclus</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Techniciens illimités</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Contrats d'entretien</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Multi-équipes & API</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Onboarding dédié</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>SLA garanti</li>
            <li><div class="pf-ck"><svg width="9" height="8" viewBox="0 0 9 8" fill="none"><path d="M1 4l2.2 3L8 1" stroke="#00D084" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Personnalisation avancée</li>
          </ul>
          <a href="/#inscription" class="price-btn">Commencer — 2 mois offerts →</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Comparison Table -->
  <div class="compare-section">
    <div class="compare-inner">
      <h2 class="compare-title reveal">Comparatif détaillé</h2>
      <div class="compare-table-wrap reveal">
        <table class="compare-table">
          <thead>
            <tr><th>Fonctionnalité</th><th>Starter</th><th class="col-feat">Pro</th><th>Business</th></tr>
          </thead>
          <tbody>
            <tr><td>Clients illimités</td><td>✓</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Fiches d'intervention</td><td>✓</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Photos d'intervention</td><td>✓</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Signature électronique eIDAS</td><td>✓</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Rapport PDF automatique</td><td>✓</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Historique complet</td><td>✓</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Mode hors ligne</td><td>✓</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>App iOS & Android</td><td>✓</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr class="sep"><td>Planning d'équipe</td><td>—</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Gestion des équipements</td><td>—</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Alertes & optimisations</td><td>—</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Tableau de bord</td><td>—</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr><td>Import / export données</td><td>—</td><td class="col-feat">✓</td><td>✓</td></tr>
            <tr class="sep"><td>Techniciens illimités</td><td>—</td><td class="col-feat">—</td><td>✓</td></tr>
            <tr><td>Contrats d'entretien</td><td>—</td><td class="col-feat">—</td><td>✓</td></tr>
            <tr><td>Multi-équipes & API</td><td>—</td><td class="col-feat">—</td><td>✓</td></tr>
            <tr><td>Onboarding dédié</td><td>—</td><td class="col-feat">—</td><td>✓</td></tr>
            <tr><td>SLA garanti</td><td>—</td><td class="col-feat">—</td><td>✓</td></tr>
            <tr class="sep"><td>Nombre de techniciens</td><td>1</td><td class="col-feat">Jusqu'à 5</td><td>Illimité</td></tr>
            <tr><td>Support</td><td>Email</td><td class="col-feat">Prioritaire</td><td>Dédié</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- FAQ Pricing -->
  <div class="pricing-faq">
    <div class="pricing-faq-inner">
      <h2 class="pricing-faq-title reveal">Questions sur les tarifs</h2>
      <div class="faq-list reveal">
        <div class="faq-item"><div class="faq-q">Comment fonctionne l'offre 2 mois offerts ?<div class="faq-arr"><svg width="11" height="7" viewBox="0 0 11 7" fill="none"><path d="M1 1l4.5 5 4.5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></div></div><div class="faq-a">Les 50 premiers inscrits à la liste d'attente bénéficieront automatiquement de 2 mois gratuits au lancement de Zerionyx. Aucune carte bancaire ne sera demandée pendant cette période. À la fin des 2 mois, vous choisissez librement votre forfait ou vous arrêtez — sans aucun frais.</div></div>
        <div class="faq-item"><div class="faq-q">Y a-t-il un engagement minimum ?<div class="faq-arr"><svg width="11" height="7" viewBox="0 0 11 7" fill="none"><path d="M1 1l4.5 5 4.5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></div></div><div class="faq-a">Non, aucun engagement. Tous les forfaits sont mensuels et résiliables à tout moment en deux clics. Pas de frais de résiliation, pas de période minimum.</div></div>
        <div class="faq-item"><div class="faq-q">Qu'est-ce qui est inclus dans le support prioritaire ?<div class="faq-arr"><svg width="11" height="7" viewBox="0 0 11 7" fill="none"><path d="M1 1l4.5 5 4.5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></div></div><div class="faq-a">Le support prioritaire (forfait Pro) vous donne accès à un temps de réponse garanti sous 4h ouvrées par email, et un accès au chat en direct avec notre équipe. Le forfait Business inclut en plus un interlocuteur dédié et des sessions de formation personnalisées.</div></div>
        <div class="faq-item"><div class="faq-q">Proposez-vous des tarifs annuels ?<div class="faq-arr"><svg width="11" height="7" viewBox="0 0 11 7" fill="none"><path d="M1 1l4.5 5 4.5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></div></div><div class="faq-a">Pas encore, mais c'est prévu. Au lancement, nous proposerons une réduction de 20% pour les abonnements annuels. En attendant, profitez de l'offre bêta avec 2 mois offerts.</div></div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <section class="pricing-cta reveal">
    <div class="pricing-cta-inner">
      <h2 class="pricing-cta-title">Prêt à gagner du temps ?</h2>
      <p class="pricing-cta-sub">Rejoignez la liste d'attente et bénéficiez de 2 mois offerts au lancement.</p>
      <a href="/#inscription" class="btn-hero-primary" style="display:inline-flex;margin-top:24px">🚀 Rejoindre la liste d'attente</a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .pricing-hero{position:relative;z-index:1;padding:80px 48px 48px;text-align:center}
  .pricing-hero-title{font-family:'Space Grotesk',sans-serif;font-size:clamp(32px,5vw,56px);font-weight:700;letter-spacing:-2px;line-height:1.05;margin-bottom:16px}
  .pricing-hero-sub{font-size:17px;color:var(--text2);max-width:560px;margin:0 auto;line-height:1.7}

  .pricing-section{position:relative;z-index:1;padding:24px 0 64px}
  .pricing-inner{max-width:1200px;margin:0 auto;padding:0 48px}
  .price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .price-card{background:var(--surface);border:1.5px solid var(--border);border-radius:20px;padding:30px;backdrop-filter:blur(8px);transition:all .25s;position:relative}
  .price-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);background:#fff}
  .price-card.feat{background:#fff;border-color:var(--blue);box-shadow:0 0 0 4px rgba(26,111,212,0.07)}
  .price-pop{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:linear-gradient(90deg,var(--blue),var(--cyan));color:#fff;font-family:'Space Grotesk',sans-serif;font-size:11px;font-weight:700;padding:4px 16px;border-radius:100px;white-space:nowrap}
  .price-name{font-family:'Space Grotesk',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:12px}
  .price-num{font-family:'Space Grotesk',sans-serif;font-size:50px;font-weight:700;letter-spacing:-2px;color:var(--text);line-height:1;margin-bottom:4px}
  .price-num sup{font-size:20px;vertical-align:top;margin-top:10px;display:inline-block}
  .price-num span{font-size:16px;font-weight:400;color:var(--text3)}
  .price-for{font-size:13px;color:var(--text2);margin-bottom:20px}
  .price-div{height:1px;background:var(--border);margin-bottom:18px}
  .price-feats{list-style:none;display:flex;flex-direction:column;gap:9px}
  .price-feats li{display:flex;align-items:flex-start;gap:8px;font-size:13px;color:var(--text2)}
  .pf-ck{width:16px;height:16px;background:var(--green-light);border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
  .price-btn{display:block;width:100%;text-align:center;margin-top:22px;padding:12px;border-radius:10px;font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;text-decoration:none;border:1.5px solid var(--blue);color:var(--blue);background:transparent}
  .price-btn:hover{background:var(--blue-glow)}
  .price-card.feat .price-btn{background:var(--blue);color:#fff;border-color:var(--blue)}
  .price-card.feat .price-btn:hover{background:var(--blue-dark)}

  /* Compare Table */
  .compare-section{position:relative;z-index:1;padding:64px 0;border-top:1px solid var(--border)}
  .compare-inner{max-width:900px;margin:0 auto;padding:0 48px}
  .compare-title{font-family:'Space Grotesk',sans-serif;font-size:28px;font-weight:700;letter-spacing:-1px;text-align:center;margin-bottom:32px}
  .compare-table-wrap{overflow-x:auto;border-radius:16px;border:1px solid var(--border);background:var(--surface);backdrop-filter:blur(8px);box-shadow:var(--shadow)}
  .compare-table{width:100%;border-collapse:collapse;font-size:14px}
  .compare-table th{font-family:'Space Grotesk',sans-serif;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);padding:16px 20px;text-align:center;border-bottom:1px solid var(--border);background:var(--bg)}
  .compare-table th:first-child{text-align:left}
  .compare-table td{padding:12px 20px;text-align:center;border-bottom:1px solid var(--border);color:var(--text2)}
  .compare-table td:first-child{text-align:left;font-weight:500;color:var(--text)}
  .compare-table tr:last-child td{border-bottom:none}
  .compare-table tr.sep td{border-top:2px solid var(--border)}
  .col-feat{background:rgba(26,111,212,0.04)}

  /* FAQ Pricing */
  .pricing-faq{position:relative;z-index:1;padding:64px 0;border-top:1px solid var(--border)}
  .pricing-faq-inner{max-width:760px;margin:0 auto;padding:0 48px}
  .pricing-faq-title{font-family:'Space Grotesk',sans-serif;font-size:28px;font-weight:700;letter-spacing:-1px;text-align:center;margin-bottom:28px}
  .faq-list{display:flex;flex-direction:column;gap:9px}
  .faq-item{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;backdrop-filter:blur(8px);transition:border-color .2s}
  .faq-item.open{border-color:var(--blue-dark) !important}
  .faq-q{display:flex;align-items:center;justify-content:space-between;padding:17px 20px;cursor:pointer;font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:600;color:var(--text);gap:12px}
  .faq-q:hover{color:var(--blue)}
  .faq-arr{width:22px;height:22px;border-radius:50%;background:var(--bg2);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .25s,background .2s}
  .faq-item.open .faq-arr{transform:rotate(180deg);background:var(--blue-glow)}
  .faq-a{display:none;padding:0 20px 16px;font-size:14px;color:var(--text2);line-height:1.7}
  .faq-item.open .faq-a{display:block;animation:fadeUp .2s ease}

  /* CTA */
  .pricing-cta{position:relative;z-index:1;padding:80px 48px;text-align:center;background:linear-gradient(180deg,var(--bg) 0%,rgba(220,235,255,0.5) 100%);border-top:1px solid var(--border)}
  .pricing-cta-inner{max-width:600px;margin:0 auto}
  .pricing-cta-title{font-family:'Space Grotesk',sans-serif;font-size:clamp(26px,3.5vw,40px);font-weight:700;letter-spacing:-1px;margin-bottom:12px}
  .pricing-cta-sub{font-size:17px;color:var(--text2);line-height:1.7}

  @media(max-width:900px){
    .pricing-hero{padding:60px 16px 32px}
    .pricing-inner,.compare-inner,.pricing-faq-inner{padding:0 16px}
    .price-grid{grid-template-columns:1fr}
    .pricing-cta{padding:64px 16px}
  }
</style>

<script>
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) { setTimeout(() => e.target.classList.add('visible'), i * 70); obs.unobserve(e.target); }
    });
  }, { threshold: 0.07 });
  document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));

  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      const item = q.parentElement!;
      const list = item.parentElement!;
      const isOpen = item.classList.contains('open');
      list.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });
</script>
