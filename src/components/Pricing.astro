<style>
  .pricing-inner{max-width:1200px;margin:0 auto;padding:96px 48px}
  .price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:48px}
  .price-card{background:var(--surface);border:1.5px solid var(--border);border-radius:20px;padding:30px;backdrop-filter:blur(8px);transition:all .25s;position:relative}
  .price-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);background:#fff}
  .price-card.feat{background:#fff;border-color:var(--blue);box-shadow:0 0 0 4px rgba(26,111,212,0.07)}
  .price-pop{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:linear-gradient(90deg,var(--blue),var(--cyan));color:#fff;font-family:'Space Grotesk',sans-serif;font-size:11px;font-weight:700;padding:4px 16px;border-radius:100px;white-space:nowrap}
  .price-name{font-family:'Space Grotesk',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:12px}
  .price-num{font-family:'Space Grotesk',sans-serif;font-size:50px;font-weight:700;letter-spacing:-2px;color:var(--text);line-height:1;margin-bottom:4px}
  .price-num sup{font-size:20px;vertical-align:top;margin-top:10px;display:inline-block;letter-spacing:0}
  .price-num span{font-size:16px;font-weight:400;color:var(--text3);letter-spacing:0}
  .price-for{font-size:13px;color:var(--text2);margin-bottom:20px}
  .price-div{height:1px;background:var(--border);margin-bottom:18px}
  .price-feats{list-style:none;display:flex;flex-direction:column;gap:9px}
  .price-feats li{display:flex;align-items:flex-start;gap:8px;font-size:13px;color:var(--text2)}
  .pf-ck{width:16px;height:16px;background:var(--green-light);border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
  .price-btn{display:block;width:100%;text-align:center;margin-top:22px;padding:12px;border-radius:10px;font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;text-decoration:none;border:1.5px solid var(--blue);color:var(--blue);background:transparent}
  .price-btn:hover{background:var(--blue-glow)}
  .price-card.feat .price-btn{background:var(--blue);color:#fff;border-color:var(--blue)}
  .price-card.feat .price-btn:hover{background:var(--blue-dark)}
  @media(max-width:900px){.pricing-inner{padding:64px 16px}.price-grid{grid-template-columns:1fr}}
</style>
