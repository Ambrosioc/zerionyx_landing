---
const API_URL = 'https://app.zerionyx.fr/api/waitlist';
---

<div style="position:relative;z-index:1;background:linear-gradient(180deg,var(--bg) 0%,rgba(220,235,255,0.5) 100%);border-top:1px solid var(--border)" id="inscription">
  <div class="cta-final-inner">
    <div class="reveal">
      <h2 class="cta-final-title">Prenez la décision<br>qui change votre quotidien.</h2>
      <p class="cta-final-sub">Rejoignez la liste d'attente et soyez parmi les premiers à utiliser Zerionyx.</p>
    </div>
    <div class="cta-form reveal" id="the-form">
      <div class="form-row">
        <input type="text" class="f-input" id="fp" placeholder="Votre prénom *" required>
        <input type="email" class="f-input" id="fe" placeholder="Email professionnel *" required>
      </div>
      <div class="form-row">
        <select class="f-select" id="fm">
          <option value="" disabled selected>Votre métier *</option>
          <option>Chauffagiste</option>
          <option>Électricien</option>
          <option>Plombier</option>
          <option>Maçon</option>
          <option>Climatisation / PAC</option>
          <option>Maintenance industrielle</option>
          <option>Autre</option>
        </select>
        <select class="f-select" id="ft">
          <option value="" disabled selected>Taille équipe</option>
          <option>Je travaille seul</option>
          <option>2 à 5 techniciens</option>
          <option>6 à 15 techniciens</option>
          <option>Plus de 15 techniciens</option>
        </select>
      </div>
      <button type="button" class="f-submit" id="submit-btn">🚀 Rejoindre la liste — 2 mois offerts →</button>
      <div class="f-note">🔒 Données confidentielles · Sans engagement · Réponse sous 24h</div>
    </div>
    <div class="success-wrap" id="suc">
      <div class="s-ico"><svg width="28" height="22" viewBox="0 0 28 22" fill="none"><path d="M2 11l7 8L26 2" stroke="#00D084" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
      <h3>Vous êtes sur la liste !</h3>
      <p>On vous contacte en avant-première dès l'ouverture de Zerionyx. Vérifiez votre boîte mail 👀</p>
    </div>
  </div>
</div>

<style>
  .cta-final-inner{max-width:720px;margin:0 auto;padding:96px 48px;text-align:center}
  .cta-final-title{font-family:'Space Grotesk',sans-serif;font-size:clamp(30px,4vw,52px);font-weight:700;letter-spacing:-1.5px;line-height:1.1;margin-bottom:14px;color:var(--text)}
  .cta-final-sub{font-size:17px;color:var(--text2);margin-bottom:40px;line-height:1.7}
  .cta-form{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:28px;backdrop-filter:blur(12px);box-shadow:var(--shadow)}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
  .f-input{background:var(--bg);border:1.5px solid var(--border2);border-radius:9px;padding:12px 14px;font-family:'Inter',sans-serif;font-size:14px;color:var(--text);outline:none;width:100%;transition:border-color .2s}
  .f-input:focus{border-color:var(--blue);background:#fff}
  .f-input::placeholder{color:var(--text3)}
  .f-select{background:var(--bg);border:1.5px solid var(--border2);border-radius:9px;padding:12px 14px;font-family:'Inter',sans-serif;font-size:14px;color:var(--text2);outline:none;width:100%;cursor:pointer;appearance:none;transition:border-color .2s}
  .f-select:focus{border-color:var(--blue)}
  .f-submit{width:100%;background:var(--blue);color:#fff;font-family:'Space Grotesk',sans-serif;font-size:15px;font-weight:700;padding:15px;border-radius:10px;border:none;cursor:pointer;margin-top:10px;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 16px rgba(26,111,212,0.3)}
  .f-submit:hover{background:var(--blue-dark);transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,111,212,0.4)}
  .f-or{display:flex;align-items:center;gap:12px;margin:16px 0;color:var(--text3);font-size:13px}
  .f-or::before,.f-or::after{content:'';flex:1;height:1px;background:var(--border)}
  .f-rdv{width:100%;background:var(--green-light);color:#005C35;font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:700;padding:13px;border-radius:10px;border:1.5px solid rgba(0,208,132,0.25);cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px}
  .f-rdv:hover{background:rgba(0,208,132,0.18);transform:translateY(-2px)}
  .f-note{font-size:12px;color:var(--text3);margin-top:12px;text-align:center}
  .success-wrap{display:none;text-align:center;padding:22px}
  .success-wrap.show{display:block}
  .s-ico{width:60px;height:60px;border-radius:50%;background:var(--green-light);border:2px solid rgba(0,208,132,0.3);display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
  .success-wrap h3{font-family:'Space Grotesk',sans-serif;font-size:22px;font-weight:700;color:#005C35;margin-bottom:8px}
  .success-wrap p{font-size:15px;color:var(--text2)}
  @media(max-width:900px){.cta-final-inner{padding:64px 16px}.form-row{grid-template-columns:1fr}}
</style>

<script define:vars={{ API_URL }}>
  document.getElementById('submit-btn')?.addEventListener('click', async () => {
    const name = document.getElementById('fp').value.trim();
    const email = document.getElementById('fe').value.trim();
    const job = document.getElementById('fm').value;
    const teamSize = document.getElementById('ft').value;
    if (!name || !email || !job) { alert('Merci de remplir les champs obligatoires (*)'); return; }
    try {
      await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, job, teamSize }),
      });
    } catch (e) {}
    document.getElementById('the-form').style.display = 'none';
    document.getElementById('suc').classList.add('show');
    const cnt = document.getElementById('cnt');
    const barSpots = document.getElementById('bar-spots');
    if (cnt) cnt.textContent = String(Math.max(0, parseInt(cnt.textContent) - 1));
    if (barSpots) barSpots.textContent = String(Math.max(0, parseInt(barSpots.textContent) - 1));
  });
</script>
